source "https://rubygems.org"

# Jekyll static site generator. GitHub Pages builds this site with the
# official "Deploy Jekyll with GitHub Pages" Actions workflow, so any
# current Jekyll version may be used (not limited to the github-pages gem).
gem "jekyll", "~> 4.3"

# webrick is no longer bundled with Ruby 3+, but `jekyll serve` needs it.
gem "webrick", "~> 1.8"
